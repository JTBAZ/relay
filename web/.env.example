# Copy to `.env.local` in this folder (`web/`).

# Relay Express API (repo root: `npm run build && npm start`). This file lives in `web/` only.
# No trailing slash. Opening this URL in a browser shows a small info page at `/` and JSON at `/api/v1/health`.
NEXT_PUBLIC_RELAY_API_URL=http://127.0.0.1:8787

# Default creator_id in the gallery UI (must match OAuth + scrape, e.g. dev_creator).
# NEXT_PUBLIC_RELAY_CREATOR_ID=dev_creator

# Public OAuth client id from Patreon developer portal (safe to expose to the browser).
# Re-authorize if you add scopes later (e.g. campaigns.posts for POST /api/v1/patreon/scrape).
NEXT_PUBLIC_PATREON_CLIENT_ID=

# Optional: omit this to auto-use whatever origin you opened (e.g. :3001 if 3000 is busy).
# If set, it must match Patreon app settings AND the URL you actually use.
# NEXT_PUBLIC_PATREON_REDIRECT_URI=http://localhost:3001/patreon/callback
