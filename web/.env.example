# Copy to `.env.local` in this folder (`web/`).
#
# Windows PowerShell: use a semicolon between commands, e.g. `cd web; npm run dev` (default port 3000; use `-p 3001` only if 3000 is busy).
#
# --- Local vs production ---
# Local dev: keep NEXT_PUBLIC_RELAY_API_URL on http://127.0.0.1:8787 (or your local API port) so the browser talks to
# your machine — do not point `.env.local` at production for day-to-day work.
# Production (e.g. Coolify): set env vars in the host UI, not in git. Use HTTPS and no trailing slash, e.g.
#   NEXT_PUBLIC_RELAY_API_URL=https://api.relayapp.me
# (or whatever public URL serves the Relay Express API). The Next app at https://relayapp.me must reach that API over
# the network. Register Patreon redirect URIs for production in the Patreon developer app, e.g.
#   https://relayapp.me/patreon/callback
#   https://relayapp.me/patreon/patron/callback
# alongside any localhost URIs you still use for dev.

# --- Supabase (browser-safe keys only) — MIG-01 ---
# Values come from Supabase Settings → API.
#
# RECOMMENDED: Set these two universal keys in Coolify (and in web/.env.local for local dev).
# The client picks these up in both dev and production — no staging/production split needed.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Legacy per-environment aliases (still supported as fallback; prefer the universal keys above):
# NEXT_PUBLIC_SUPABASE_STAGING_URL=https://YOUR_STAGING_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_STAGING_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PRODUCTION_URL=https://YOUR_PRODUCTION_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PRODUCTION_ANON_KEY=
#
# Relay Express API (repo root: `npm run build && npm start`). This file lives in `web/` only.
# Media export retries (Patreon blob download) are configured on the API: see repo root `.env.example` (RELAY_EXPORT_*).
# No trailing slash. Opening this URL in a browser shows a small info page at `/` and JSON at `/api/v1/health`.
# Server-side (e.g. library ZIP download): Next.js proxies `GET /api/relay/library-zip` to this host so HTTPS UI can reach HTTP Relay.
# Debug: open GET /api/relay/ping while `next dev` is running — confirms this Next process can reach Relay `/api/v1/health`.
NEXT_PUBLIC_RELAY_API_URL=http://127.0.0.1:8787

# MT-036: Studio routes (/, /designer, /action-center) require `relay_session_token` in localStorage unless you set
# the bypass below. After Supabase sign-in on /login or /onboarding, the app calls sync → relay-session → workspace
# and stores `relay_creator_id` — that id drives Library/Designer (not this env var).
# NEXT_PUBLIC_RELAY_STUDIO_AUTH_DISABLED=1
#
# Legacy dev-only fallback when there is **no** Relay session: default creator_id for gallery API calls.
# Do **not** point production at a single shared dev id — each artist should sign in so `relay_creator_id` applies.
# If unset at build time, unauthenticated fallback is **creator_1** (may not match your Patreon OAuth creator).
# NEXT_PUBLIC_RELAY_CREATOR_ID=dev_creator

# Optional numeric Patreon campaign id when the creator has multiple campaigns (Library Patreon sync menu).
NEXT_PUBLIC_RELAY_PATREON_CAMPAIGN_ID=15782831

# Display name in the Library header (larger title). Defaults to "Dev Creator" if unset.
# NEXT_PUBLIC_RELAY_CREATOR_DISPLAY_NAME=Dev Creator

# Visitor route (/visitor): hero uses API visitor_hero when the Relay API returns it (campaign banner/avatar from
# Patreon sync + RELAY_CREATOR_DISPLAY_NAME on the API). These env vars are fallbacks only.
# NEXT_PUBLIC_RELAY_VISITOR_DISPLAY_NAME=Your Studio
# NEXT_PUBLIC_RELAY_VISITOR_TAGLINE=Illustration & process
#
# Optional hero imagery fallbacks (absolute URLs) when the API has no campaign snapshot yet.
# NEXT_PUBLIC_RELAY_VISITOR_BANNER_URL=https://example.com/banner.jpg
# NEXT_PUBLIC_RELAY_VISITOR_AVATAR_URL=https://example.com/avatar.png
#
# Show a small dev control on /visitor to simulate patron tier access (API must set RELAY_DEV_VISITOR_TIER_SIM=true).
# NEXT_PUBLIC_RELAY_VISITOR_DEV_TOOLS=true

# Patron feed mock (/patron/feed): dev overlay to switch Mock fixtures vs Live API (Bearer from localStorage).
# NEXT_PUBLIC_RELAY_PATRON_FEED_DEV_TOOLS=true
# Optional default when the overlay is hidden: fixtures | live (defaults to fixtures).
# NEXT_PUBLIC_RELAY_PATRON_FEED_DEFAULT=fixtures
#
# Live feed: Relay API serves GET /api/v1/patron/relay_feed from web/lib/patron-relay-feed-bundle.json
# (regenerate: npx tsx -e "import { getPatronFeedFixtureBundle } from './web/lib/relay-fixtures.ts'; import { writeFileSync } from 'fs'; writeFileSync('web/lib/patron-relay-feed-bundle.json', JSON.stringify(getPatronFeedFixtureBundle()));")

# MT-035: Default `/patreon/connect` uses POST /auth/patreon/creator/prepare + signed state (requires
# relay_session_token + workspace relay_creator_id in localStorage). Set to `1` only for local dev to restore
# the old “manual creator_id as OAuth state” link (do not use in production).
# NEXT_PUBLIC_RELAY_PATREON_LEGACY_CONNECT=1
#
# Public OAuth client id from Patreon developer portal (same value as repo root PATREON_CLIENT_ID).
# Re-authorize if you add scopes later (e.g. campaigns.posts for POST /api/v1/patreon/scrape).
NEXT_PUBLIC_PATREON_CLIENT_ID=
#
# Same Client ID, server-only — read at **runtime** (use in production when NEXT_PUBLIC was empty at build).
# Duplicate of root .env PATREON_CLIENT_ID; connect pages resolve PATREON_CLIENT_ID first, then NEXT_PUBLIC_*.
# PATREON_CLIENT_ID=

# Optional: omit this to auto-use whatever origin you opened (recommended for local dev, e.g. http://127.0.0.1:3000/patreon/callback).
# If set, Patreon receives this exact URI — do NOT put your production relayapp.me URL in web/.env.local while testing on localhost
# or Patreon will error ("Redirect URI … is not supported by client"). Use production redirect only on the hosted front end (Coolify env).
# NEXT_PUBLIC_PATREON_REDIRECT_URI=http://localhost:3000/patreon/callback
#
# Patron “Log in with Patreon” callback (defaults to {origin}/patreon/patron/callback).
# Register this redirect URI in the same Patreon OAuth app; scopes differ from creator connect.
# If unset, opening the app as http://127.0.0.1:3000 still uses http://localhost:3000/patreon/patron/callback
# so it matches a Patreon app that only lists localhost (see web/lib/patron-patron-redirect-uri.ts).
# NEXT_PUBLIC_PATREON_PATRON_REDIRECT_URI=http://localhost:3000/patreon/patron/callback
