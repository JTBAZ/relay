# Copy to `.env.local` in this folder (`web/`) for local Next.js + Relay API dev.
#
# Steps:
#   1. cp .env.local.example .env.local   (or copy manually on Windows)
#   2. From repo root: npm run build && npm start   (Relay API, default :8787)
#   3. From web/: npm run dev   (Next on :3000; see package.json)
#
# Full catalog (Supabase, Patreon, patron feed toggles, etc.): `.env.example` in this folder.

# Browser + Relay API origin — no trailing slash. Same value is read by next.config.mjs for rewrites
# (e.g. GET /api/relay/library-zip → ${NEXT_PUBLIC_RELAY_API_URL}/api/v1/export/library-zip).
NEXT_PUBLIC_RELAY_API_URL=http://127.0.0.1:8787

# Optional: set to the origin you actually open (metadata, OAuth). See `.env.example` § canonical browser origin.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
