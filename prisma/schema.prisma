// --- Milestone 9 — future-ready stubs (schema only; no app wiring). See `docs/database/integration-roadmap.md` M9. ---

/// Part 3 K — follow graph; `relay_creator_id` is ingest / gallery scope string (not `CreatorProfile.id`).
model PatronFollow {
  id                 String   @id @default(cuid())
  patronMembershipId String   @map("patron_user_id")
  relayCreatorId     String   @map("relay_creator_id")
  createdAt          DateTime @default(now()) @map("created_at")

  membership TenantMembership @relation(fields: [patronMembershipId], references: [id], onDelete: Cascade)

  @@unique([patronMembershipId, relayCreatorId], map: "patron_follow_scope_unique")
  @@index([relayCreatorId])
  @@map("patron_follows")
}

model PatronEntitlementSnapshot {
  id                 String            @id @default(cuid())
  patronMembershipId String            @map("patron_user_id")
  relayCreatorId     String            @map("relay_creator_id")
  /// Optional: upstream Patreon `campaign_id` when the snapshot is campaign-scoped (aligns with `CreatorProfile.patreonCampaignId` / `Campaign.id`).
  campaignId         String?           @map("campaign_id")
  entitledTierIds    String[]          @default([]) @map("entitled_tier_ids")
  active             Boolean
  source             EntitlementSource
  asOf               DateTime          @map("as_of")
  staleAfter         DateTime?         @map("stale_after")

  membership TenantMembership @relation(fields: [patronMembershipId], references: [id], onDelete: Cascade)

  @@unique([patronMembershipId, relayCreatorId])
  @@index([relayCreatorId])
  @@index([campaignId])
  @@map("patron_entitlement_snapshots")
}

/// Normalized campaign-level access rows (stub for future wiring; MT-005).
model PatronCampaignAccess {
  id                 String           @id @default(cuid())
  tenantMembershipId String           @map("tenant_membership_id")
  membership         TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  relayCreatorId     String           @map("relay_creator_id")
  campaignId         String           @map("campaign_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([tenantMembershipId, relayCreatorId, campaignId])
  @@index([relayCreatorId, campaignId])
  @@map("patron_campaign_access")
}

/// Part 3 L — feed pagination cursors per patron.
model FeedCursor {
  id                 String   @id @default(cuid())
  patronMembershipId String   @map("patron_user_id")
  cursorKey          String   @map("cursor_key")
  cursorValue        String?  @map("cursor_value")
  updatedAt          DateTime @updatedAt @map("updated_at")

  membership TenantMembership @relation(fields: [patronMembershipId], references: [id], onDelete: Cascade)

  @@unique([patronMembershipId, cursorKey])
  @@map("feed_cursors")
}

/// Part 3 K — notification / privacy preference rows.
model NotificationPreference {
  id                 String   @id @default(cuid())
  patronMembershipId String   @map("patron_user_id")
  relayCreatorId     String   @map("relay_creator_id")
  preferenceType     String   @map("preference_type")
  enabled            Boolean  @default(true)
  updatedAt          DateTime @updatedAt @map("updated_at")

  membership TenantMembership @relation(fields: [patronMembershipId], references: [id], onDelete: Cascade)

  @@unique([patronMembershipId, relayCreatorId, preferenceType])
  @@map("notification_preferences")
}

/// Optional patron OAuth token persistence (Part 3 K) — one row per `Account` (global Patreon link).
model PatronOAuthCredential {
  id               String           @id @default(cuid())
  accountId        String           @unique @map("account_id")
  account          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  encryptedPayload Bytes            @map("encrypted_payload")
  keyId            String           @map("key_id")
  healthStatus     CredentialHealth @map("health_status")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("patron_oauth_credentials")
}

/// Part 3 O — comments (soft-delete via `deleted_at`).
model Comment {
  id             String          @id @default(cuid())
  relayCreatorId String          @map("relay_creator_id")
  postId         String          @map("post_id")
  patronUserId   String          @map("patron_user_id")
  body           String
  createdAt      DateTime        @default(now()) @map("created_at")
  deletedAt      DateTime?       @map("deleted_at")
  modState       CommentModState @default(visible) @map("mod_state")

  @@index([relayCreatorId, postId])
  @@index([patronUserId])
  @@map("relay_comments")
}

/// Part 3 L/M — ranking / discovery audit (partitioning deferred; index on `created_at` for time-range queries).
model DiscoveryDecisionLog {
  id             String   @id @default(cuid())
  patronUserId   String?  @map("patron_user_id")
  relayCreatorId String?  @map("relay_creator_id")
  itemKey        String   @map("item_key")
  rankScore      Float?   @map("rank_score")
  reasonCodes    String[] @default([]) @map("reason_codes")
  inputsJson     Json     @map("inputs_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("discovery_decision_logs")
}

/// Smart Tag Assistant — vector column is a `Bytes` placeholder until pgvector is enabled (see `relational-model.md`).
model EmbeddingStub {
  id            String @id @default(cuid())
  creatorId     String @map("creator_id")
  entityType    String @map("entity_type")
  entityId      String @map("entity_id")
  modelVersion  String @map("model_version")
  embeddingBlob Bytes? @map("embedding_blob")

