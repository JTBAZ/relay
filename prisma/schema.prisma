// Relay — PostgreSQL via Prisma (see root `.env.example` DATABASE_URL).
// M2: identity · M3: canonical · M4: creator curation (`docs/database/relational-model.md`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Identity & multi-tenancy (M2.1) ---

/// In-app role for rows in `users` (creator/staff). Patron authorization uses `TenantMembership` + `TenantRole`.
enum UserKind {
  creator
  staff
}

/// Per-tenant role for an `Account` (Option B — Multi Tenant Changes).
enum TenantRole {
  patron
}

enum ProviderKind {
  patreon
  subscribestar
}

enum OAuthPurpose {
  creator_ingest
  patron_entitlement
}

enum CredentialHealth {
  healthy
  degraded
  invalid
  revoked
}

/// Part 3 K/L — how a `PatronEntitlementSnapshot` was produced (M9 stub).
enum EntitlementSource {
  oauth_exchange
  scheduled_refresh
  webhook
  manual_support
}

/// Part 3 O — comment moderation (M9 stub). PE-E (BO-P2-03) keeps the same three states; auto-mod transitions "visible -> hidden" without removing.
enum CommentModState {
  visible
  hidden
  removed
}

/// PE-E (D12) — who is allowed to see a comment when the post itself is visible to the viewer.
/// Tier requirement on the comment is layered on TOP of this via Comment.requiredTierId (NOT replacing post-level gating).
enum CommentVisibility {
  everyone
  patrons_only
}

/// PE-E — surface a comment-driven content report points at.
enum ContentReportTargetKind {
  comment
  post
  account
}

/// PE-E — lifecycle for ContentReport rows.
enum ContentReportStatus {
  open
  dismissed
  actioned
}

/// PE-E — actor that produced a ModerationAction row.
enum ModerationActorKind {
  creator
  admin
  system_auto_mod
  patron_self
}

/// PE-E — what surface a ModerationAction was applied to.
enum ModerationTargetKind {
  comment
  post
  account
}

/// PE-E — kinds of moderation actions logged. Append-only audit trail; reversible actions log a paired entry rather than mutating the original log row.
enum ModerationActionKind {
  comment_hide
  comment_unhide
  comment_remove
  comment_restore
  comment_pin
  comment_unpin
  comment_tag_revoke
  comment_tag_unrevoke
  account_block
  account_unblock
  report_dismiss
  report_action
  auto_mod_flag
}

/// PE-E (D12) — types of reactions on a comment (small fixed set; expand cautiously to keep aggregation cheap).
enum CommentReactionKind {
  like
  heart
  insightful
  laugh
}

/// PE-C — audit row when patron creator-follows are seeded (OAuth or worker).
/// How `CreatorProfile.publicSlug` was chosen (automation vs user).
enum PublicSlugSource {
  allocated
  patreon_default
  user_chosen
}

enum PatronFollowSeedSource {
  oauth_unified
  oauth_creator_scoped_exchange
  initial_follow_worker
}

/// Mirrors `UserAccount.auth_provider` in `src/identity/types.ts` (independent email/password vs Patreon-linked).
enum IdentityAuthProvider {
  independent
  patreon
}

/// Web (`relay_session` / Bearer) vs browser extension opaque grant (sliding 30d TTL).
enum SessionKind {
  web       @map("web")
  extension @map("extension")
}

model Tenant {
  id             String   @id @default(cuid())
  /// Relay `creator_id` (e.g. ingest / gallery scope) — unique tenant for DbIdentityStore.
  relayCreatorId String?  @unique @map("relay_creator_id")
  createdAt      DateTime @default(now()) @map("created_at")

  users          User[]
  memberships    TenantMembership[]
  creators       CreatorProfile[]
  /// At most one `Account` may claim this tenant as its primary artist studio (MT-031).
  primaryAccount Account?           @relation("AccountPrimaryStudio")
  /// M1-lite / P7 — append-only usage metering (`docs/database/usage-events-rollups.md`).
  usageEvents    UsageEvent[]

  @@map("tenants")
}

/// P7 M1-lite — append-only per-tenant (or unattributed) usage events for metering and rollups.
model UsageEvent {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  metric     String
  /// Whole units (e.g. bytes transferred, or 1 for discrete events). See `meta` for detail.
  quantity   BigInt   @default(1) @map("quantity")
  meta       Json?    @map("meta")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([tenantId, occurredAt])
  @@index([metric, occurredAt])
  @@map("usage_events")
}

/// Global login identity — one person per row (Option B). Patrons are scoped per creator via `TenantMembership`.
model Account {
  id                    String               @id @default(cuid())
  emailHash             String?              @map("email_hash")
  /// Global normalized email (unique when set) — `DbIdentityStore.findByEmail` uses this + `TenantMembership`.
  emailNorm             String?              @unique @map("email_norm")
  passwordHash          String?              @map("password_hash")
  identityAuthProvider  IdentityAuthProvider @map("identity_auth_provider")
  /// Global Patreon user id when linked (unique when set).
  patronPatreonUserId   String?              @unique @map("patron_patreon_user_id")
  /// Supabase Auth `auth.users.id` (Pattern A, ADR 001). Null until linked (MIG-11+).
  supabaseUserId        String?              @unique @map("supabase_user_id") @db.Uuid
  /// Artist studio scope — matches `Tenant.relayCreatorId` when this account owns a creator workspace (MT-031). Null for patron-only accounts.
  primaryRelayCreatorId String?              @unique @map("primary_relay_creator_id")
  /// Backfill trace: stable id from `identity.json` / file store era (see integration-roadmap 2.3.x).
  legacyFileId          String?              @map("legacy_file_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  memberships           TenantMembership[]
  patronOAuthCredential PatronOAuthCredential?
  primaryStudio         Tenant?                 @relation("AccountPrimaryStudio", fields: [primaryRelayCreatorId], references: [relayCreatorId], onDelete: SetNull, onUpdate: Cascade)
  followsOutgoing       AccountFollow[]         @relation("AccountFollowsOutgoing")
  followsIncoming       AccountFollow[]         @relation("AccountFollowsIncoming")
  discordLinkTokens     DiscordLinkToken[]
  discordBindingsLinked DiscordChannelBinding[] @relation("DiscordChannelBindingLinker")

  @@map("accounts")
}

/// Per-tenant membership for an `Account` (tier entitlements, patron sessions, etc.).
model TenantMembership {
  id           String     @id @default(cuid())
  accountId    String     @map("account_id")
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId     String     @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         TenantRole @default(patron)
  tierIds      String[]   @default([]) @map("tier_ids")
  legacyFileId String?    @map("legacy_file_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  sessions                    Session[]
  patronProfile               PatronProfile?
  patronFollows               PatronFollow[]
  patronEntitlementSnapshots  PatronEntitlementSnapshot[]
  patronCampaignAccessRecords PatronCampaignAccess[]
  feedCursors                 FeedCursor[]
  notificationPreferences     NotificationPreference[]
  notifications               Notification[]
  patronFollowSeeds           PatronFollowSeed[]

  @@unique([accountId, tenantId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

/// Creator/staff rows only — patron identity is `Account` + `TenantMembership`.
model User {
  id                   String               @id @default(cuid())
  tenantId             String               @map("tenant_id")
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  kind                 UserKind
  identityAuthProvider IdentityAuthProvider @map("identity_auth_provider")
  tierIds              String[]             @default([]) @map("tier_ids")
  /// Backfill trace for creator rows when applicable.
  legacyFileId         String?              @map("legacy_file_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  providerAccounts ProviderAccount[]
  creatorProfile   CreatorProfile?

  @@index([tenantId, kind])
  @@map("users")
}

model Session {
  id                 String           @id @default(cuid())
  tenantMembershipId String           @map("tenant_membership_id")
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  /// SHA-256 (or app-defined hash) of opaque token only — never store raw tokens (operations-and-security.md).
  tokenHash          String           @unique @map("token_hash")
  /// Backfill trace for file-backed sessions (integration-roadmap 2.3.x).
  legacyFileId       String?          @map("legacy_file_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  expiresAt          DateTime?        @map("expires_at")
  userAgent          String?          @map("user_agent")
  ipInet             String?          @map("ip_inet")
  revokedAt          DateTime?        @map("revoked_at")
  kind               SessionKind      @default(web) @map("kind")
  /// User-visible label (e.g. extension install + UA), set on extension issue.
  label              String?          @map("label")
  /// Sliding-window anchor for extension grants (`touchSessionExpiry`).
  lastUsedAt         DateTime?        @map("last_used_at")

  @@index([tenantMembershipId, kind, expiresAt])
  @@map("sessions")
}

model ProviderAccount {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       ProviderKind
  providerUserId String       @map("provider_user_id")
  displayName    String?      @map("display_name")
  createdAt      DateTime     @default(now()) @map("created_at")

  oauthCredential OAuthCredential?

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("provider_accounts")
}

model OAuthCredential {
  id                String           @id @default(cuid())
  providerAccountId String           @unique @map("provider_account_id")
  providerAccount   ProviderAccount  @relation(fields: [providerAccountId], references: [id], onDelete: Cascade)
  purpose           OAuthPurpose
  encryptedPayload  Bytes            @map("encrypted_payload")
  keyId             String           @map("key_id")
  healthStatus      CredentialHealth @map("health_status")
  lastSuccessAt     DateTime?        @map("last_success_at")
  lastFailureAt     DateTime?        @map("last_failure_at")
  lastFailureCode   String?          @map("last_failure_code")
  expiresAtHint     DateTime?        @map("expires_at_hint")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("oauth_credentials")
}

model CreatorProfile {
  id                String           @id @default(cuid())
  tenantId          String           @map("tenant_id")
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  userId            String           @unique @map("user_id")
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Public URL segment for `/patron/c/{public_slug}` — unique, lowercase, `[a-z0-9-]`.
  publicSlug        String           @unique @map("public_slug")
  /// Provenance for `publicSlug`: opaque default, Patreon campaign vanity, or explicit user edit.
  slugSource        PublicSlugSource @default(allocated) @map("slug_source")
  /// Canonical Patreon `campaign_id` for this creator (ingest / webhooks / patron matching). See `docs/architecture/multi-tenant-option-b.md`.
  patreonCampaignId String?          @unique @map("patreon_campaign_id")
  /// Canonical SubscribeStar creator/profile id for creator-side ingest and patron matching.
  subscribestarProfileId String?     @unique @map("subscribestar_profile_id")
  /// Mutable public @handle (mixed case allowed); uniqueness is on `usernameNorm`.
  username          String?
  /// Lowercase normalized username for uniqueness; mirrors `PatronProfile.handleNorm` pattern.
  usernameNorm      String?          @unique @map("username_norm")
  displayName       String?          @map("display_name")
  avatarUrl         String?          @map("avatar_url")
  bannerUrl         String?          @map("banner_url")
  /// Short bio, capped at 280 chars by the service layer.
  bio               String?
  /// Free-text creative discipline (e.g. "Digital Illustrator"), rendered in feed cards.
  discipline        String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([patreonCampaignId])
  @@index([subscribestarProfileId])
  @@map("creator_profiles")
}

model PatronProfile {
  id                 String           @id @default(cuid())
  tenantMembershipId String           @unique @map("tenant_membership_id")
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  /// Display / entry handle (mixed case allowed); uniqueness is on `handleNorm`.
  handle             String?
  /// Lowercase normalized handle for uniqueness and `/p/[handle]` (D16).
  handleNorm         String?          @unique @map("handle_norm")
  displayName        String?          @map("display_name")
  bio                String?
  avatarUrl          String?          @map("avatar_url")
  bannerUrl          String?          @map("banner_url")
  /// Default false until the patron opts into a public presence (D16).
  isPublic           Boolean          @default(false) @map("is_public")
  /// Onboarding wizard progress 0–4 (PE-A skeleton).
  onboardingStep     Int              @default(0) @map("onboarding_step")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("patron_profiles")
}

// --- Canonical ingest + gallery (M3 Phase 3.1) — string `creator_id` matches Relay ingest scope (see `canonical-store.ts`) ---

enum PostUpstreamStatus {
  active
  deleted
}

enum MediaUpstreamStatus {
  active
  deleted
}

/// Origin of a `Post` row: mirrored from Patreon vs created in Relay.
enum PostSource {
  PATREON
  SUBSCRIBESTAR
  RELAY
}

/// How a `MediaAsset` was first ingested: upstream sync vs direct Relay upload vs Discord capture.
enum MediaIngestOrigin {
  PATREON
  SUBSCRIBESTAR
  RELAY_UPLOAD
  DISCORD
}

/// Relay direct-upload pipeline visibility (creator UI); Patreon-ingested rows stay READY.
enum MediaProcessingStatus {
  PENDING_UPLOAD
  UPLOADED
  READY
  FAILED
}

/// Patreon (or mapped) campaign row — `id` is stable `campaign_id` from `CampaignRow` / ingest.
model Campaign {
  id                String   @id
  creatorId         String   @map("creator_id")
  name              String
  upstreamUpdatedAt DateTime @map("upstream_updated_at")
  versionSeq        Int      @map("version_seq")

  posts Post[]
  tiers Tier[]

  @@index([creatorId])
  @@map("campaigns")
}

/// Access tier — `id` is a stable synthetic key (e.g. `${creator_id}::${relay_tier_id}`) because relay tier keys repeat across creators.
model Tier {
  id                String    @id @map("id")
  creatorId         String    @map("creator_id")
  /// File / API tier key (`TierRow.tier_id`), e.g. `patreon_tier_123`, `RELAY_TIER_PUBLIC`.
  relayTierId       String    @map("relay_tier_id")
  /// Opaque provider id for idempotency (Patreon tier id or same as `relay_tier_id` when unknown).
  providerTierId    String    @map("provider_tier_id")
  /// When this row is a `relay_manual_tier_*` folder, optional canonical provider-access key uploads must match (`patreon_tier_*` / `substar_tier_*`).
  manualUploadAccessRelayTierId String? @map("manual_upload_access_relay_tier_id")
  campaignId        String?   @map("campaign_id")
  campaign          Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  title             String
  amountCents       Int?      @map("amount_cents")
  upstreamUpdatedAt DateTime  @map("upstream_updated_at")
  versionSeq        Int       @map("version_seq")

  postTiers PostTier[]

  @@unique([creatorId, providerTierId])
  @@index([creatorId])
  @@map("tiers")
}

/// Post — `id` is stable `post_id` from `PostRow` / ingest.
model Post {
  id             String             @id @map("id")
  campaignId     String             @map("campaign_id")
  campaign       Campaign           @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  creatorId      String             @map("creator_id")
  /// Opaque idempotency key from upstream when known. **PATREON** ingest sets this to the same
  /// value as `id` (stable `post_id` in snapshot, e.g. `patreon_post_…`) so `@@unique([campaignId, providerPostId])` applies.
  /// **RELAY** native posts: keep `null`; uniqueness is the primary key `id` (e.g. cuid). PG allows many `(campaign_id, null)` rows.
  providerPostId String?            @map("provider_post_id")
  upstreamStatus PostUpstreamStatus @map("upstream_status")
  /// Gallery / feed ordering — set from ingest (e.g. earliest `published_at` in versions).
  createdAt      DateTime           @map("created_at")
  /// Tier 1 RLS — when true, post is readable without tier membership (anon + any logged-in user).
  isPublic       Boolean            @default(false) @map("is_public")
  /// Tier 1 RLS — patrons must have this tier id in `TenantMembership.tier_ids` when not public; null with `is_public` false = creator-only (draft).
  requiredTierId String?            @map("required_tier_id")
  /// Patreon sync only mutates `PATREON`; Relay-native posts use `RELAY` and are out of sync blast radius.
  source         PostSource         @default(PATREON) @map("source")

  versions     PostVersion[]
  postTiers    PostTier[]
  mediaAssets  MediaAsset[]
  /// Creator-controlled presentation overlays (titles, descriptions, ordering, tier previews).
  /// Merged at read time with append-only ingest (`PostVersion`); ingest must not mutate this row.
  presentation PostPresentation?
  /// P5a — Patreon Insights CSV rows linked when `patreon_post_id` matches `id` or `provider_post_id`.
  patreonInsightsPostMetrics PatreonInsightsPostMetric[]
  relayEngagementEvents      RelayEngagementEvent[]

  @@unique([campaignId, providerPostId])
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([creatorId, source])
  @@map("posts")
}

model PostVersion {
  id               String   @id @default(cuid())
  postId           String   @map("post_id")
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  versionSeq       Int      @map("version_seq")
  upstreamRevision String   @map("upstream_revision")
  title            String
  description      String?
  publishedAt      DateTime @map("published_at")
  tagIds           String[] @default([]) @map("tag_ids")
  tierIds          String[] @default([]) @map("tier_ids")
  mediaIds         String[] @default([]) @map("media_ids")
  ingestedAt       DateTime @map("ingested_at")

  @@unique([postId, versionSeq])
  @@index([postId])
  @@map("post_versions")
}

/// Media — `id` is stable `media_id` from `MediaRow`. `primary_post_id` indexes the canonical post link; `post_ids` mirrors file M:N.
model MediaAsset {
  id                      String                 @id @map("id")
  creatorId               String                 @map("creator_id")
  postIds                 String[]               @default([]) @map("post_ids")
  /// Set after attach to a `Post` (Patreon ingest or Relay publish). Null while upload-only (T-3.2) or if post was deleted.
  primaryPostId           String?                @map("primary_post_id")
  post                    Post?                  @relation(fields: [primaryPostId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  upstreamStatus          MediaUpstreamStatus    @map("upstream_status")
  currentVersionSeq       Int                    @map("current_version_seq")
  currentUpstreamRevision String                 @map("current_upstream_revision")
  currentMimeType         String?                @map("current_mime_type")
  currentUpstreamUrl      String?                @map("current_upstream_url")
  currentRole             String?                @map("current_role")
  /// Object key under tenant storage (e.g. export `media/{id}/asset` or future R2 key). Not a public premium CDN URL.
  currentStorageKey       String?                @map("current_storage_key")
  currentIngestedAt       DateTime               @map("current_ingested_at")
  versionsJson            Json                   @map("versions_json")
  /// Patreon sync / export path vs future direct upload; default PATREON for legacy rows.
  ingestOrigin            MediaIngestOrigin      @default(PATREON) @map("ingest_origin")
  processingStatus        MediaProcessingStatus  @default(READY) @map("processing_status")
  processingError         String?                @map("processing_error")
  /// Discord-only: message/channel/attachment snowflakes and caption snapshot (see Phase 1 Discord capture).
  discordCaptureJson      Json?                  @map("discord_capture_json")
  /// Coordinate-pinned comments referencing this asset (`Comment.media_id`).
  commentPins             Comment[]
  discordIngestReceipt    DiscordMediaIngestKey?
  relayEngagementEvents   RelayEngagementEvent[]
  /// Manual Import: staged uploads carry intended provider access (`v:1`) before compose/publish (`primaryPostId` null).
  manualImportStagingJson Json? @map("manual_import_staging_json")

  @@index([primaryPostId])
  @@index([creatorId, ingestOrigin])
  @@map("media_assets")
}

model PostTier {
  postId String @map("post_id")
  tierId String @map("tier_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([postId, tierId])
  @@map("post_tiers")
}

/// Replaces file-backed `SyncWatermarkStore` (`last_synced_at` per creator + campaign).
model SyncCursor {
  creatorId    String   @map("creator_id")
  campaignId   String   @map("campaign_id")
  lastSyncedAt DateTime @map("last_synced_at")
  updatedAt    DateTime @map("updated_at")

  @@id([creatorId, campaignId])
  @@map("sync_cursors")
}

/// Replaces file-backed `PatreonSyncHealthStore` (`last_post_scrape` / `last_member_sync` JSON blobs).
model CreatorSyncState {
  creatorId      String   @id @map("creator_id")
  lastPostScrape Json?    @map("last_post_scrape")
  lastMemberSync Json?    @map("last_member_sync")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("creator_sync_states")
}

/// Provider-scoped sync snapshots keep Patreon and SubscribeStar health independent.
model CreatorProviderSyncState {
  creatorId      String       @map("creator_id")
  provider       ProviderKind
  lastPostSync   Json?        @map("last_post_sync")
  lastMemberSync Json?        @map("last_member_sync")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@id([creatorId, provider])
  @@map("creator_provider_sync_states")
}

/// P4-onb-001 — Part 1-A creator funnel: Connect Patreon → Import → Organize → Publish (persisted step + optional JSON metadata).
enum CreatorOnboardingStep {
  /// Patreon linked; backfill default for existing creators before finer-grained transitions ship.
  connected
  /// Initial import path entered (e.g. after creator OAuth success — P4-onb-004).
  import_started
  /// Library / organize phase acknowledged (P4-onb-005).
  organized
  /// Public gallery has been published at least once.
  published
}

/// One row per Relay `creator_id` (ingest scope; aligns with `Campaign.creatorId` / `CreatorSyncState`).
model CreatorOnboardingState {
  creatorId String                @id @map("creator_id")
  step      CreatorOnboardingStep @default(connected) @map("step")
  /// Small JSON only (flags, timestamps); no PII — service layer enforces shape.
  metadata  Json?                 @map("metadata")
  updatedAt DateTime              @updatedAt @map("updated_at")

  @@map("creator_onboarding_states")
}

/// Replaces `ingest_idempotency` map in `canonical.json` — `batch_key` is the SHA-256 hex from `ingestIdempotencyKey()`.
model IngestIdempotencyKey {
  id          String   @id @default(cuid())
  creatorId   String   @map("creator_id")
  batchKey    String   @map("batch_key")
  firstSeenAt DateTime @map("first_seen_at")

  @@unique([creatorId, batchKey])
  @@index([creatorId])
  @@map("ingest_idempotency_keys")
}

// --- Creator curation (M4 Phase 4.1) — Relay `creator_id` scope strings; no FK to `CreatorProfile` (see canonical pattern). ---

enum GalleryVisibility {
  visible
  hidden
  review
}

/// Replaces `gallery_post_overrides.json` — one row per (creator, post, media scope).
///
/// PE-F (BO-P3-01) — `discoveryEligible` opts the post into `GET /api/v1/patron/discover`.
/// Only meaningful on post-level rows (mediaId=""); per-media rows ignore the flag because
/// discovery surfaces whole posts, not individual assets. Default false: opt-in only, no
/// surprise public exposure when the override row is created for some other reason.
model PostOverride {
  id                String             @id @default(cuid())
  creatorId         String             @map("creator_id")
  postId            String             @map("post_id")
  /// Empty string = post-level override; otherwise canonical `media_id` for per-asset rows.
  mediaId           String             @default("") @map("media_id")
  addTagIds         String[]           @default([]) @map("add_tag_ids")
  removeTagIds      String[]           @default([]) @map("remove_tag_ids")
  visibility        GalleryVisibility?
