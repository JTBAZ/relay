// Relay — PostgreSQL via Prisma (see root `.env.example` DATABASE_URL).
// M2: identity · M3: canonical · M4: creator curation (`docs/database/relational-model.md`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Identity & multi-tenancy (M2.1) ---

/// In-app role for rows in `users` (creator/staff). Patron authorization uses `TenantMembership` + `TenantRole`.
enum UserKind {
  creator
  staff
}

/// Per-tenant role for an `Account` (Option B — Multi Tenant Changes).
enum TenantRole {
  patron
}

enum ProviderKind {
  patreon
}

enum OAuthPurpose {
  creator_ingest
  patron_entitlement
}

enum CredentialHealth {
  healthy
  degraded
  invalid
  revoked
}

/// Part 3 K/L — how a `PatronEntitlementSnapshot` was produced (M9 stub).
enum EntitlementSource {
  oauth_exchange
  scheduled_refresh
  webhook
  manual_support
}

/// Part 3 O — comment moderation (M9 stub).
enum CommentModState {
  visible
  hidden
  removed
}

/// Mirrors `UserAccount.auth_provider` in `src/identity/types.ts` (independent email/password vs Patreon-linked).
enum IdentityAuthProvider {
  independent
  patreon
}

model Tenant {
  id             String   @id @default(cuid())
  /// Relay `creator_id` (e.g. ingest / gallery scope) — unique tenant for DbIdentityStore.
  relayCreatorId String?  @unique @map("relay_creator_id")
  createdAt      DateTime @default(now()) @map("created_at")

  users          User[]
  memberships    TenantMembership[]
  creators       CreatorProfile[]
  /// At most one `Account` may claim this tenant as its primary artist studio (MT-031).
  primaryAccount Account?           @relation("AccountPrimaryStudio")

  @@map("tenants")
}

/// Global login identity — one person per row (Option B). Patrons are scoped per creator via `TenantMembership`.
model Account {
  id                    String               @id @default(cuid())
  emailHash             String?              @map("email_hash")
  /// Global normalized email (unique when set) — `DbIdentityStore.findByEmail` uses this + `TenantMembership`.
  emailNorm             String?              @unique @map("email_norm")
  passwordHash          String?              @map("password_hash")
  identityAuthProvider  IdentityAuthProvider @map("identity_auth_provider")
  /// Global Patreon user id when linked (unique when set).
  patronPatreonUserId   String?              @unique @map("patron_patreon_user_id")
  /// Supabase Auth `auth.users.id` (Pattern A, ADR 001). Null until linked (MIG-11+).
  supabaseUserId        String?              @unique @map("supabase_user_id") @db.Uuid
  /// Artist studio scope — matches `Tenant.relayCreatorId` when this account owns a creator workspace (MT-031). Null for patron-only accounts.
  primaryRelayCreatorId String?              @unique @map("primary_relay_creator_id")
  /// Backfill trace: stable id from `identity.json` / file store era (see integration-roadmap 2.3.x).
  legacyFileId          String?              @map("legacy_file_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  memberships           TenantMembership[]
  patronOAuthCredential PatronOAuthCredential?
  primaryStudio         Tenant?                @relation("AccountPrimaryStudio", fields: [primaryRelayCreatorId], references: [relayCreatorId], onDelete: SetNull, onUpdate: Cascade)

  @@map("accounts")
}

/// Per-tenant membership for an `Account` (tier entitlements, patron sessions, etc.).
model TenantMembership {
  id           String     @id @default(cuid())
  accountId    String     @map("account_id")
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId     String     @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         TenantRole @default(patron)
  tierIds      String[]   @default([]) @map("tier_ids")
  legacyFileId String?    @map("legacy_file_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  sessions                    Session[]
  patronProfile               PatronProfile?
  patronFollows               PatronFollow[]
  patronEntitlementSnapshots  PatronEntitlementSnapshot[]
  patronCampaignAccessRecords PatronCampaignAccess[]
  feedCursors                 FeedCursor[]
  notificationPreferences     NotificationPreference[]

  @@unique([accountId, tenantId])
  @@index([tenantId])
  @@map("tenant_memberships")
}

/// Creator/staff rows only — patron identity is `Account` + `TenantMembership`.
model User {
  id                   String               @id @default(cuid())
  tenantId             String               @map("tenant_id")
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  kind                 UserKind
  identityAuthProvider IdentityAuthProvider @map("identity_auth_provider")
  tierIds              String[]             @default([]) @map("tier_ids")
  /// Backfill trace for creator rows when applicable.
  legacyFileId         String?              @map("legacy_file_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  providerAccounts ProviderAccount[]
  creatorProfile   CreatorProfile?

  @@index([tenantId, kind])
  @@map("users")
}

model Session {
  id                 String           @id @default(cuid())
  tenantMembershipId String           @map("tenant_membership_id")
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  /// SHA-256 (or app-defined hash) of opaque token only — never store raw tokens (operations-and-security.md).
  tokenHash          String           @unique @map("token_hash")
  /// Backfill trace for file-backed sessions (integration-roadmap 2.3.x).
  legacyFileId       String?          @map("legacy_file_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  expiresAt          DateTime?        @map("expires_at")
  userAgent          String?          @map("user_agent")
  ipInet             String?          @map("ip_inet")
  revokedAt          DateTime?        @map("revoked_at")

  @@index([tenantMembershipId, expiresAt])
  @@map("sessions")
}

model ProviderAccount {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       ProviderKind
  providerUserId String       @map("provider_user_id")
  displayName    String?      @map("display_name")
  createdAt      DateTime     @default(now()) @map("created_at")

  oauthCredential OAuthCredential?

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("provider_accounts")
}

model OAuthCredential {
  id                String           @id @default(cuid())
  providerAccountId String           @unique @map("provider_account_id")
  providerAccount   ProviderAccount  @relation(fields: [providerAccountId], references: [id], onDelete: Cascade)
  purpose           OAuthPurpose
  encryptedPayload  Bytes            @map("encrypted_payload")
  keyId             String           @map("key_id")
  healthStatus      CredentialHealth @map("health_status")
  lastSuccessAt     DateTime?        @map("last_success_at")
  lastFailureAt     DateTime?        @map("last_failure_at")
  lastFailureCode   String?          @map("last_failure_code")
  expiresAtHint     DateTime?        @map("expires_at_hint")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("oauth_credentials")
}

model CreatorProfile {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  userId            String   @unique @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Public URL segment for `/patron/c/{public_slug}` — unique, lowercase, `[a-z0-9-]`.
  publicSlug        String   @unique @map("public_slug")
  /// Canonical Patreon `campaign_id` for this creator (ingest / webhooks / patron matching). See `docs/architecture/multi-tenant-option-b.md`.
  patreonCampaignId String?  @unique @map("patreon_campaign_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([patreonCampaignId])
  @@map("creator_profiles")
}

model PatronProfile {
  id                 String           @id @default(cuid())
  tenantMembershipId String           @unique @map("tenant_membership_id")
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  handle             String?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("patron_profiles")
}

// --- Canonical ingest + gallery (M3 Phase 3.1) — string `creator_id` matches Relay ingest scope (see `canonical-store.ts`) ---

enum PostUpstreamStatus {
  active
  deleted
}

enum MediaUpstreamStatus {
  active
  deleted
}

/// Patreon (or mapped) campaign row — `id` is stable `campaign_id` from `CampaignRow` / ingest.
model Campaign {
  id                String   @id
  creatorId         String   @map("creator_id")
  name              String
  upstreamUpdatedAt DateTime @map("upstream_updated_at")
  versionSeq        Int      @map("version_seq")

  posts Post[]
  tiers Tier[]

  @@index([creatorId])
  @@map("campaigns")
}

/// Access tier — `id` is a stable synthetic key (e.g. `${creator_id}::${relay_tier_id}`) because relay tier keys repeat across creators.
model Tier {
  id                String    @id @map("id")
  creatorId         String    @map("creator_id")
  /// File / API tier key (`TierRow.tier_id`), e.g. `patreon_tier_123`, `RELAY_TIER_PUBLIC`.
  relayTierId       String    @map("relay_tier_id")
  /// Opaque provider id for idempotency (Patreon tier id or same as `relay_tier_id` when unknown).
  providerTierId    String    @map("provider_tier_id")
  campaignId        String?   @map("campaign_id")
  campaign          Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  title             String
  amountCents       Int?      @map("amount_cents")
  upstreamUpdatedAt DateTime  @map("upstream_updated_at")
  versionSeq        Int       @map("version_seq")

  postTiers PostTier[]

  @@unique([creatorId, providerTierId])
  @@index([creatorId])
  @@map("tiers")
}

/// Post — `id` is stable `post_id` from `PostRow` / ingest.
model Post {
  id             String             @id @map("id")
  campaignId     String             @map("campaign_id")
  campaign       Campaign           @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  creatorId      String             @map("creator_id")
  /// Patreon/API post id for idempotency when distinct from Relay `post_id`.
  providerPostId String?            @map("provider_post_id")
  upstreamStatus PostUpstreamStatus @map("upstream_status")
  /// Gallery / feed ordering — set from ingest (e.g. earliest `published_at` in versions).
  createdAt      DateTime           @map("created_at")

  versions    PostVersion[]
  postTiers   PostTier[]
  mediaAssets MediaAsset[]

  @@unique([campaignId, providerPostId])
  @@index([campaignId, createdAt(sort: Desc)])
  @@map("posts")
}

model PostVersion {
  id               String   @id @default(cuid())
  postId           String   @map("post_id")
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  versionSeq       Int      @map("version_seq")
  upstreamRevision String   @map("upstream_revision")
  title            String
  description      String?
  publishedAt      DateTime @map("published_at")
  tagIds           String[] @default([]) @map("tag_ids")
  tierIds          String[] @default([]) @map("tier_ids")
  mediaIds         String[] @default([]) @map("media_ids")
  ingestedAt       DateTime @map("ingested_at")

  @@unique([postId, versionSeq])
  @@index([postId])
  @@map("post_versions")
}

/// Media — `id` is stable `media_id` from `MediaRow`. `primary_post_id` indexes the canonical post link; `post_ids` mirrors file M:N.
model MediaAsset {
  id                      String              @id @map("id")
  creatorId               String              @map("creator_id")
  postIds                 String[]            @default([]) @map("post_ids")
  primaryPostId           String              @map("primary_post_id")
  post                    Post                @relation(fields: [primaryPostId], references: [id], onDelete: Cascade)
  upstreamStatus          MediaUpstreamStatus @map("upstream_status")
  currentVersionSeq       Int                 @map("current_version_seq")
  currentUpstreamRevision String              @map("current_upstream_revision")
  currentMimeType         String?             @map("current_mime_type")
  currentUpstreamUrl      String?             @map("current_upstream_url")
  currentRole             String?             @map("current_role")
  /// Object key under tenant storage (e.g. export `media/{id}/asset` or future R2 key). Not a public premium CDN URL.
  currentStorageKey       String?             @map("current_storage_key")
  currentIngestedAt       DateTime            @map("current_ingested_at")
  versionsJson            Json                @map("versions_json")

  @@index([primaryPostId])
  @@map("media_assets")
}

model PostTier {
  postId String @map("post_id")
  tierId String @map("tier_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([postId, tierId])
  @@map("post_tiers")
}

/// Replaces file-backed `SyncWatermarkStore` (`last_synced_at` per creator + campaign).
model SyncCursor {
  creatorId    String   @map("creator_id")
  campaignId   String   @map("campaign_id")
  lastSyncedAt DateTime @map("last_synced_at")
  updatedAt    DateTime @map("updated_at")

  @@id([creatorId, campaignId])
  @@map("sync_cursors")
}

/// Replaces file-backed `PatreonSyncHealthStore` (`last_post_scrape` / `last_member_sync` JSON blobs).
model CreatorSyncState {
  creatorId      String   @id @map("creator_id")
  lastPostScrape Json?    @map("last_post_scrape")
  lastMemberSync Json?    @map("last_member_sync")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("creator_sync_states")
}

/// Replaces `ingest_idempotency` map in `canonical.json` — `batch_key` is the SHA-256 hex from `ingestIdempotencyKey()`.
model IngestIdempotencyKey {
  id          String   @id @default(cuid())
  creatorId   String   @map("creator_id")
  batchKey    String   @map("batch_key")
  firstSeenAt DateTime @map("first_seen_at")

  @@unique([creatorId, batchKey])
  @@index([creatorId])
  @@map("ingest_idempotency_keys")
}

// --- Creator curation (M4 Phase 4.1) — Relay `creator_id` scope strings; no FK to `CreatorProfile` (see canonical pattern). ---

enum GalleryVisibility {
  visible
  hidden
  review
}

/// Replaces `gallery_post_overrides.json` — one row per (creator, post, media scope).
model PostOverride {
  id           String             @id @default(cuid())
  creatorId    String             @map("creator_id")
  postId       String             @map("post_id")
  /// Empty string = post-level override; otherwise canonical `media_id` for per-asset rows.
  mediaId      String             @default("") @map("media_id")
  addTagIds    String[]           @default([]) @map("add_tag_ids")
  removeTagIds String[]           @default([]) @map("remove_tag_ids")
  visibility   GalleryVisibility?
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([creatorId, postId, mediaId])
  @@index([creatorId])
  @@map("post_overrides")
}

/// Replaces artist `collections.json` Library rows — `id` is stable `collection_id` from file.
model LibraryCollection {
  id                  String   @id @map("id")
  creatorId           String   @map("creator_id")
  title               String
  description         String?
  coverMediaId        String?  @map("cover_media_id")
  accessCeilingTierId String?  @map("access_ceiling_tier_id")
  themeTagIds         String[] @default([]) @map("theme_tag_ids")
  sortOrder           Int      @map("sort_order")
  createdAt           DateTime @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  posts CollectionPost[]

  @@index([creatorId])
  @@map("library_collections")
}

model CollectionPost {
  collectionId String @map("collection_id")
  postId       String @map("post_id")
  sortIndex    Int    @map("sort_index")

  collection LibraryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([collectionId, postId])
  @@index([collectionId])
  @@map("collection_posts")
}

/// Replaces `gallery_saved_filters.json` — `id` is stable `filter_id` from file.
model SavedFilter {
  id        String   @id @map("id")
  creatorId String   @map("creator_id")
  name      String
  query     Json
  createdAt DateTime @map("created_at")

  @@index([creatorId])
  @@map("saved_filters")
}

/// Replaces `page_layout.json` — one row per Relay `creator_id`; full layout in JSON for round-trip.
model PageLayout {
  creatorId  String   @id @map("creator_id")
  layoutJson Json     @map("layout_json")
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("page_layouts")
}

// --- Operations / DLQ (M5) — `ingest_dlq.json` + durable events (`InMemoryEventBus` replacement). ---

/// Ingest dead-letter and future job runs (`DbDeadLetterQueue` uses `kind = ingest_dlq`).
model JobRun {
  id           String    @id @map("id")
  kind         String
  creatorId    String    @map("creator_id")
  status       String
  traceId      String    @map("trace_id")
  payload      Json?
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  error        String?
  attemptCount Int       @default(0) @map("attempt_count")
  dlqBatch     Json?     @map("dlq_batch")

  @@index([creatorId, status])
  @@map("job_runs")
}

/// Durable outbox; dedupe on (event_name, tenant_id, primary_id, occurred_at) per `events.md`.
model OutboxEvent {
  id         String   @id @default(cuid())
  eventId    String   @unique @map("event_id")
  eventName  String   @map("event_name")
  tenantId   String   @map("tenant_id")
  primaryId  String   @map("primary_id")
  occurredAt DateTime @map("occurred_at")
  traceId    String   @map("trace_id")
  producer   String
  version    String
  payload    Json

  @@unique([eventName, tenantId, primaryId, occurredAt])
  @@index([occurredAt])
  @@map("outbox_events")
}

// --- Analytics & Action Center (M6) — replaces `.relay-data/analytics.json` when using DbAnalyticsStore. ---

model AnalyticsSnapshotRow {
  snapshotId  String   @id @map("snapshot_id")
  creatorId   String   @map("creator_id")
  kind        String   @default("canonical_rollup")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  generatedAt DateTime @map("generated_at")
  estimated   Boolean
  label       String?
  method      String?
  payload     Json

  @@index([creatorId, kind, periodStart, periodEnd])
  @@map("analytics_snapshots")
}

model RecommendationRecord {
  recommendationId   String   @id @map("recommendation_id")
  creatorId          String   @map("creator_id")
  tenantId           String?  @map("tenant_id")
  cardType           String   @map("card_type")
  title              String
  signal             String
  diagnosis          String
  recommendationBody String   @map("recommendation_body")
  confidenceScore    Float    @map("confidence_score")
  expectedImpact     Json     @map("expected_impact")
  reasonCodes        String[] @default([]) @map("reason_codes")
  evidenceRefs       String[] @default([]) @map("evidence_refs")
  status             String
  createdAt          DateTime @map("created_at")
  updatedAt          DateTime @map("updated_at")
  notes              String?
  dismissReasonCode  String?  @map("dismiss_reason_code")

  @@index([creatorId])
  @@map("recommendation_records")
}

model AnalyticsActionExecution {
  actionJobId      String   @id @map("action_job_id")
  recommendationId String   @map("recommendation_id")
  creatorId        String   @map("creator_id")
  actionType       String   @map("action_type")
  options          Json
  executionStatus  String   @map("execution_status")
  createdAt        DateTime @map("created_at")

  @@index([creatorId])
  @@map("action_executions")
}

model AnalyticsOutcome {
  id               String   @id @default(cuid())
  recommendationId String   @map("recommendation_id")
  creatorId        String   @map("creator_id")
  evaluatedAt      DateTime @map("evaluated_at")
  metric           String
  predictedDelta   Float    @map("predicted_delta")
  actualDelta      Float    @map("actual_delta")

  @@index([creatorId, recommendationId])
  @@map("recommendation_outcomes")
}

// --- Patron engagement (M7) — replaces `.relay-data/patron_favorites.json` + `patron_collections.json`. ---

enum PatronFavoriteTargetKind {
  post
  media
}

/// Maps `PatronFavoriteRecord` / `patron_favorites.json`; stable scope is `(patron_membership_id, creator_id, target_kind, target_id)`.
model PatronFavorite {
  id                 String                   @id @default(cuid())
  patronMembershipId String                   @map("patron_user_id")
  creatorId          String                   @map("creator_id")
  targetKind         PatronFavoriteTargetKind @map("target_kind")
  targetId           String                   @map("target_id")
  createdAt          DateTime                 @map("created_at")

  @@unique([patronMembershipId, creatorId, targetKind, targetId], map: "patron_favorite_scope_unique")
  @@index([patronMembershipId, creatorId])
  @@map("patron_favorites")
}

/// Patron-owned snip collection — `id` is stable `collection_id` from file (`pcol_*`).
model PatronSavedCollection {
  id                 String   @id @map("id")
  patronMembershipId String   @map("user_id")
  creatorId          String   @map("creator_id")
  title              String
  sortOrder          Int      @map("sort_order")
  createdAt          DateTime @map("created_at")
  updatedAt          DateTime @map("updated_at")

  entries PatronSavedCollectionEntry[]

  @@index([creatorId, patronMembershipId])
  @@map("patron_saved_collections")
}

/// Entry in a patron snip collection — `id` is stable `entry_id` from file (`pent_*`).
model PatronSavedCollectionEntry {
  id                 String                @id @map("id")
  collectionId       String                @map("collection_id")
  collection         PatronSavedCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  patronMembershipId String                @map("user_id")
  creatorId          String                @map("creator_id")
  postId             String                @map("post_id")
  mediaId            String                @map("media_id")
  createdAt          DateTime              @map("created_at")

  @@unique([patronMembershipId, creatorId, collectionId, mediaId], map: "patron_saved_entry_media_unique")
  @@index([collectionId])
  @@index([creatorId, patronMembershipId])
  @@map("patron_saved_collection_entries")
}

// --- Part 2 backend (M8) — clone, payments, migrations, deploys (replaces `.relay-data/*.json`). ---

/// One row per creator — full `CloneSiteModel` JSON (`clone_sites.json`).
model CloneSite {
  creatorId String @id @map("creator_id")
  payload   Json

  @@map("clone_sites")
}

/// Per-creator Stripe/PayPal mapping (`payments.json` configs map) — no raw provider secrets in columns.
model CreatorPaymentConfig {
  creatorId String   @id @map("creator_id")
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment_configs")
}

/// Append-only checkout results (`payments.json` checkouts array).
model PaymentCheckout {
  checkoutId   String   @id @map("checkout_id")
  tierId       String   @map("tier_id")
  provider     String
  status       String
  amountCents  Int      @map("amount_cents")
  currency     String
  dryRun       Boolean  @map("dry_run")
  processedAt  DateTime @map("processed_at")
  errorMessage String?  @map("error_message")

  @@index([processedAt])
  @@map("payment_checkouts")
}

/// Re-audience migration campaign payload (`migrations.json` campaigns map).
model AudienceMigrationCampaign {
  campaignId String   @id @map("campaign_id")
  creatorId  String   @map("creator_id")
  payload    Json
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([creatorId])
  @@map("migration_campaigns")
}

/// Append-only audit log (`migrations.json` audit_log) — insert only in application code.
model MigrationAuditEntry {
  id         String   @id @default(cuid())
  ts         DateTime @map("timestamp")
  campaignId String   @map("campaign_id")
  creatorId  String   @map("creator_id")
  action     String
  detail     String

  @@index([campaignId])
  @@index([creatorId])
  @@index([ts])
  @@map("migration_audit_entries")
}

model MigrationSuppressionEntry {
  id        String @id @default(cuid())
  creatorId String @map("creator_id")
  emailNorm String @map("email_norm")

  @@unique([creatorId, emailNorm])
  @@index([creatorId])
  @@map("migration_suppression_entries")
}

model MigrationSignedLink {
  token     String   @id
  memberId  String   @map("member_id")
  tierId    String   @map("tier_id")
  url       String
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("migration_signed_links")
}

model Deployment {
  deploymentId    String    @id @map("deployment_id")
  creatorId       String    @map("creator_id")
  siteId          String    @map("site_id")
  provider        String
  status          String
  domain          String?
  previewUrl      String    @map("preview_url")
  productionUrl   String?   @map("production_url")
  dnsCheck        Json?     @map("dns_check")
  createdAt       DateTime  @map("created_at")
  approvedAt      DateTime? @map("approved_at")
  launchedAt      DateTime? @map("launched_at")
  rolledBackAt    DateTime? @map("rolled_back_at")
  rollbackFromId  String?   @map("rollback_from_id")
  buildDurationMs Int?      @map("build_duration_ms")

  @@index([creatorId])
  @@map("deployments")
}

model CreatorActiveDeployment {
