/// PE-G (BO-P3-03) — kinds of notification a patron can receive.
///
/// v1 set covers the events for which producers exist (or are added in this lane). Adding a
/// new kind is additive: extend this enum + extend `outbox-to-notification mapper` and the
/// existing fan-out keeps working.
enum NotificationKind {
  comment_replied
  comment_liked
  new_follower
  tier_changed
  new_post_followed
  mention
}

/// PE-G (BO-P3-03) — durable per-recipient notification rows.
///
/// Producers emit `OutboxEvent`s; the delivery worker reads new events, calls the mapper to
/// resolve the recipient set + payload, and writes one `Notification` row per recipient. A
/// recipient's notification feed is a `findMany` against this table ordered by `createdAt DESC`.
///
/// Clustering: when `clusterKey` is set, repeated events (e.g. multiple likes on the same
/// comment) are coalesced into the SAME row -- the worker increments `clusterCount` and bumps
/// `updatedAt` rather than writing a new row. The original `payloadJson` shape decides how the
/// UI renders "5 people liked your comment" vs the singleton case.
///
/// Read state: `readAt` null = unread. The mark-read endpoint is the only writer; the worker
/// never touches `readAt`.
model Notification {
  id                    String           @id @default(cuid())
  /// TenantMembership.id for the recipient. Indexed; the patron feed query filters on this.
  recipientMembershipId String           @map("recipient_membership_id")
  /// Optional creator scope -- when set, filters / preferences operate per-creator.
  relayCreatorId        String           @default("") @map("relay_creator_id")
  kind                  NotificationKind
  /// Free-form, kind-shaped payload. Examples:
  ///   tier_changed:     { prior_tier_ids, next_tier_ids, active }
  ///   comment_liked:    { post_id, comment_id, latest_actor_account_id }
  ///   comment_replied:  { post_id, comment_id, parent_comment_id, reply_account_id }
  ///   new_follower:     { follower_account_id }
  payloadJson           Json             @map("payload_json")
  /// Optional dedupe key for clustering. NULL = never coalesce. Same key + same recipient + an
  /// existing unread row inside CLUSTER_WINDOW_MS = increment count; new row otherwise.
  clusterKey            String?          @map("cluster_key")
  /// How many underlying events have been folded into this row (>= 1). Always 1 for un-clustered.
  clusterCount          Int              @default(1) @map("cluster_count")
  /// FK-style trace back to the OutboxEvent that produced this notification (most-recent for clusters).
  /// When `cluster_key` is null, Postgres enforces uniqueness on (`source_event_id`, `recipient_membership_id`)
  /// so concurrent delivery ticks cannot insert duplicate rows for the same outbox event + recipient
  /// (see migration `20260508160000_notifications_nonclustered_source_recipient_unique`).
  sourceEventId         String?          @map("source_event_id")
  /// Read state. Null = unread.
  readAt                DateTime?        @map("read_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  membership TenantMembership @relation(fields: [recipientMembershipId], references: [id], onDelete: Cascade)

  @@index([recipientMembershipId, readAt, createdAt(sort: Desc)])
  @@index([recipientMembershipId, clusterKey])
  @@map("notifications")
}

/// PE-G (BO-P3-03) — single-row cursor table; tracks the timestamp up to which the
/// notification delivery worker has processed `OutboxEvent` rows. Re-reading from the cursor
/// on restart keeps delivery exactly-once-ish (we still rely on the OutboxEvent dedupe key
/// AND clusterKey de-duplication so a re-process is safe).
///
/// Single-row pattern: id is fixed to "default"; multi-instance deploys can swap to a Redis
/// lock + cursor (BullMQ leader election) without schema changes.
model NotificationDeliveryCursor {
  id             String   @id @default("default")
  lastOccurredAt DateTime @map("last_occurred_at")
  lastEventId    String?  @map("last_event_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("notification_delivery_cursor")
}

/// PE-J (BO-P4-02) — patron-initiated account deletion lifecycle.
///
/// status:
///   - pending   : delete request accepted; sweeper picks it up at scheduledFor.
///   - executed  : sweeper has run the cascade + soft-FK purge.
///   - cancelled : patron cancelled before scheduledFor (or admin override).
///
/// We intentionally allow only ONE active pending row per account at a time (uniqueness
/// enforced at the service layer + a partial index could be added later via raw SQL when
/// concurrent abuse becomes a concern).
enum AccountDeletionStatus {
  pending
  executed
  cancelled
}

model AccountDeletion {
  id           String                @id @default(cuid())
  accountId    String                @map("account_id")
  status       AccountDeletionStatus @default(pending)
  /// When the patron initiated the request.
  requestedAt  DateTime              @default(now()) @map("requested_at")
  /// Wall-clock when the sweeper is allowed to execute. Default = requestedAt + 7 days.
  scheduledFor DateTime              @map("scheduled_for")
  /// Set when status transitions to executed.
  executedAt   DateTime?             @map("executed_at")
  /// Set when status transitions to cancelled.
  cancelledAt  DateTime?             @map("cancelled_at")
  /// Optional patron-supplied reason; surfaced in moderator analytics, not in audit logs.
  reason       String?
  /// Best-effort source IP for fraud triage. Null when middleware doesn't surface it.
  requesterIp  String?               @map("requester_ip")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@index([accountId])
  @@index([status, scheduledFor])
  @@map("account_deletions")
}

/// Optional patron OAuth token persistence (Part 3 K) — one row per `Account` (global Patreon link).
model PatronOAuthCredential {
  id               String           @id @default(cuid())
  accountId        String           @unique @map("account_id")
  account          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  encryptedPayload Bytes            @map("encrypted_payload")
  keyId            String           @map("key_id")
  healthStatus     CredentialHealth @map("health_status")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("patron_oauth_credentials")
}

/// Part 3 O + PE-E (BO-P2-03) — comments (soft-delete via `deleted_at`).
///
/// PE-E additive fields (D12, D26, D27, D28):
/// - mediaId / anchorX / anchorY: D26 coordinate-pinned comments. mediaId null = post-level. AnchorX/Y are
///   percentage coordinates (0.0 - 100.0) on the rendered media's natural box.
/// - parentCommentId: simple threading; one level deep is enough for V1 but the FK self-relation supports deeper nesting later.
/// - editedAt + EDIT_WINDOW_MS (15 min) enforced at the service layer in src/patron/comment-service.ts.
/// - creatorPinnedAt: D12 creator pin (top-of-thread). Distinct from coordinate pinning (anchorX/Y) -- those are author-supplied, this is creator-curated.
/// - requiredTierId + visibility: D12 tier-gated comments layered ON TOP of post-level gating (never widen access).
/// - tagIds: D27 patron-supplied tags. Mirror to TagSuggestion(source = "patron_comment") via src/patron/comment-tag-service.ts so they flow into effectiveTags() automatically.
/// - tagsRevokedByOwner: granular per-comment per-tag owner revocation (subset of tagIds). When the LAST suggestion backing a (media, tag) is revoked, the post's PostOverride.removeTagIds gains the tag.
/// - autoModFlagsJson: snapshot of the auto-mod ruleset hits at create time, for transparency and post-hoc tuning.
model Comment {
  id                 String            @id @default(cuid())
  relayCreatorId     String            @map("relay_creator_id")
  postId             String            @map("post_id")
  /// D26 — null = post-level comment; non-null = coordinate-pinned (`MediaAsset.id`). FK `onDelete: SetNull` keeps the row if media is removed upstream (coordinates may be stale until edited).
  mediaId            String?           @map("media_id")
  mediaAsset         MediaAsset?       @relation(fields: [mediaId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// D26 — percentage X coordinate (0-100) on the rendered media's natural box. Required when mediaId is set.
  anchorX            Decimal?          @map("anchor_x") @db.Decimal(5, 2)
  /// D26 — percentage Y coordinate (0-100). Required when mediaId is set.
  anchorY            Decimal?          @map("anchor_y") @db.Decimal(5, 2)
  patronUserId       String            @map("patron_user_id")
  body               String
  /// D12 - simple threading; null = top-level. Self-relation; parent delete cascades to children (matches typical comment UX).
  parentCommentId    String?           @map("parent_comment_id")
  parent             Comment?          @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies            Comment[]         @relation("CommentReplies")
  /// D27 - patron-supplied tags shared with artist namespace.
  tagIds             String[]          @default([]) @map("tag_ids")
  /// D27 - granular per-comment owner revocation. Subset of tagIds. See SEARCH_AND_TAGS_SHARED_KERNEL.md §4.3.
  tagsRevokedByOwner String[]          @default([]) @map("tags_revoked_by_owner")
  /// D12 - creator pin to top of thread. Distinct from coordinate pinning. Null = unpinned.
  creatorPinnedAt    DateTime?         @map("creator_pinned_at")
  /// D12 - optional tier gate; when set, viewer must have this tier id in current TenantMembership.tierIds.
  requiredTierId     String?           @map("required_tier_id")
  /// D12 - audience scope (defaults to everyone == post audience).
  visibility         CommentVisibility @default(everyone)
  /// D22 - auto-mod hits captured at create-time; stored as { rule_id, snippet, severity }[] for explainability.
  autoModFlagsJson   Json?             @map("auto_mod_flags_json")
  createdAt          DateTime          @default(now()) @map("created_at")
  /// Last edit timestamp; null = never edited.
  editedAt           DateTime?         @map("edited_at")
  deletedAt          DateTime?         @map("deleted_at")
  modState           CommentModState   @default(visible) @map("mod_state")

  reactions CommentReaction[]

  @@index([relayCreatorId, postId])
  @@index([relayCreatorId, postId, mediaId])
  @@index([patronUserId])
  @@index([parentCommentId])
  @@map("relay_comments")
}

/// PE-E (D12) — one row per (comment, account, kind). Toggle on/off; aggregate counts at read time.
model CommentReaction {
  id        String              @id @default(cuid())
  commentId String              @map("comment_id")
  comment   Comment             @relation(fields: [commentId], references: [id], onDelete: Cascade)
  accountId String              @map("account_id")
  kind      CommentReactionKind
  createdAt DateTime            @default(now()) @map("created_at")

  @@unique([commentId, accountId, kind])
  @@index([commentId])
  @@index([accountId])
  @@map("comment_reactions")
}

/// PE-E — patron-submitted reports on comments / posts / accounts; resolved by creator/admin via ModerationAction.
model ContentReport {
  id                  String                  @id @default(cuid())
  reporterAccountId   String                  @map("reporter_account_id")
  /// Scope: usually the relay_creator_id whose surface this is about (creator's queue). For account reports this can be empty when scope is platform-wide.
  relayCreatorId      String                  @default("") @map("relay_creator_id")
  targetKind          ContentReportTargetKind @map("target_kind")
  targetId            String                  @map("target_id")
  reasonCode          String                  @map("reason_code")
  body                String?
  status              ContentReportStatus     @default(open)
  resolvedByAccountId String?                 @map("resolved_by_account_id")
  resolvedAt          DateTime?               @map("resolved_at")
  createdAt           DateTime                @default(now()) @map("created_at")

  @@index([relayCreatorId, status, createdAt])
  @@index([targetKind, targetId])
  @@index([reporterAccountId])
  @@map("content_reports")
}

/// PE-E — append-only moderation audit log. Reversible actions log a paired entry (e.g. comment_hide -> comment_unhide).
model ModerationAction {
  id             String               @id @default(cuid())
  /// Scope; "" allowed for platform-wide actions.
  relayCreatorId String               @default("") @map("relay_creator_id")
  actorKind      ModerationActorKind  @map("actor_kind")
  /// Null when actorKind = system_auto_mod.
  actorAccountId String?              @map("actor_account_id")
  kind           ModerationActionKind
  targetKind     ModerationTargetKind @map("target_kind")
  targetId       String               @map("target_id")
  /// Free-form payload for kind-specific data: { tagId } for comment_tag_revoke, { reportId } for report_*, etc.
  payloadJson    Json?                @map("payload_json")
  createdAt      DateTime             @default(now()) @map("created_at")

  @@index([relayCreatorId, createdAt])
  @@index([targetKind, targetId])
  @@index([actorAccountId])
  @@map("moderation_actions")
}

/// PE-E (D14) — account-level block. Future-only semantics: hides content authored AFTER createdAt; historical content unaffected.
model AccountBlock {
  id               String   @id @default(cuid())
  blockerAccountId String   @map("blocker_account_id")
  blockedAccountId String   @map("blocked_account_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([blockerAccountId, blockedAccountId])
  @@index([blockerAccountId])
  @@index([blockedAccountId])
  @@map("account_blocks")
}

/// Part 3 L/M — ranking / discovery audit (partitioning deferred; index on `created_at` for time-range queries).
model DiscoveryDecisionLog {
  id             String   @id @default(cuid())
  patronUserId   String?  @map("patron_user_id")
  relayCreatorId String?  @map("relay_creator_id")
  itemKey        String   @map("item_key")
  rankScore      Float?   @map("rank_score")
  reasonCodes    String[] @default([]) @map("reason_codes")
  inputsJson     Json     @map("inputs_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("discovery_decision_logs")
}

/// Smart Tag Assistant — vector column is a `Bytes` placeholder until pgvector is enabled (see `relational-model.md`).
model EmbeddingStub {
  id            String @id @default(cuid())
  creatorId     String @map("creator_id")
  entityType    String @map("entity_type")
  entityId      String @map("entity_id")
  modelVersion  String @map("model_version")
  embeddingBlob Bytes? @map("embedding_blob")

  @@unique([creatorId, entityType, entityId, modelVersion], map: "embedding_stub_scope_unique")
  @@index([creatorId])
  @@map("smart_tag_embeddings")
}

model TagSuggestion {
  id         String    @id @default(cuid())
  creatorId  String    @map("creator_id")
  mediaId    String    @map("media_id")
  tagId      String    @map("tag_id")
  confidence Float
  source     String
  acceptedAt DateTime? @map("accepted_at")
  rejectedAt DateTime? @map("rejected_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([creatorId, mediaId])
  @@map("tag_suggestions")
}

// --- Discord channel capture → staging (Phase 1) ---

/// One watched Discord channel per Relay studio (`relay_creator_id` = ingest / gallery scope string).
model DiscordChannelBinding {
  id                String   @id @default(cuid())
  relayCreatorId    String   @unique @map("relay_creator_id")
  discordGuildId    String   @map("discord_guild_id")
  discordChannelId  String   @map("discord_channel_id")
  linkedByAccountId String?  @map("linked_by_account_id")
  linkedBy          Account? @relation("DiscordChannelBindingLinker", fields: [linkedByAccountId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([discordGuildId, discordChannelId])
  @@map("discord_channel_bindings")
}

/// Short-lived minted codes for in-Discord `/relay-link`-style handshake; store **hash** only (never plaintext).
model DiscordLinkToken {
  id             String    @id @default(cuid())
  codeHash       String    @unique @map("code_hash")
  relayCreatorId String    @map("relay_creator_id")
  accountId      String    @map("account_id")
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt      DateTime  @map("expires_at")
  consumedAt     DateTime? @map("consumed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([relayCreatorId, expiresAt])
  @@map("discord_link_tokens")
}

/// Idempotent Discord attachment → `MediaAsset` mapping (retry-safe ingest).
model DiscordMediaIngestKey {
  id                  String     @id @default(cuid())
  discordGuildId      String     @map("discord_guild_id")
  discordChannelId    String     @map("discord_channel_id")
  discordMessageId    String     @map("discord_message_id")
  discordAttachmentId String     @map("discord_attachment_id")
  mediaAssetId        String     @unique @map("media_asset_id")
  mediaAsset          MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt           DateTime   @default(now()) @map("created_at")

  @@unique([discordGuildId, discordChannelId, discordMessageId, discordAttachmentId], map: "discord_ingest_key_quad_uq")
  @@map("discord_media_ingest_keys")
}

/// Deferred R2 object deletion (e.g. Discord staging discard after `MediaAsset` row is removed).
model MediaStoragePurgeQueue {
  id            String   @id @default(cuid())
  storageKey    String   @map("storage_key")
  creatorId     String   @map("creator_id")
  formerMediaId String?  @map("former_media_id")
  reason        String
  eligibleAt    DateTime @map("eligible_at")
  createdAt     DateTime @default(now()) @map("created_at")
  attempts      Int      @default(0)
  lastError     String?  @map("last_error")

  @@index([eligibleAt])
  @@index([createdAt])
  @@map("media_storage_purge_queue")
}

/// Narrow replacement target for `patreon_webhook_metadata.json` (encrypted secret + key id only).
model WebhookEndpoint {
  id                       String   @id @default(cuid())
  relayCreatorId           String   @unique @map("relay_creator_id")
  patreonCampaignNumericId String?  @map("patreon_campaign_numeric_id")
  encryptedSecret          Bytes?   @map("encrypted_secret")
  keyId                    String?  @map("key_id")
  opaqueDeliveryToken      String?  @unique @map("opaque_delivery_token")
  patreonWebhookId         String?  @map("patreon_webhook_id")
  uriRegistered            String?  @map("uri_registered")
  registrationStatus       String?  @map("registration_status")
  triggers                 Json?    @map("webhook_triggers")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("webhook_endpoints")
}
