// Relay — PostgreSQL via Prisma (see root `.env.example` DATABASE_URL).
// M2: identity · M3: canonical · M4: creator curation (`docs/database/relational-model.md`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Identity & multi-tenancy (M2.1) ---

enum UserKind {
  creator
  patron
  staff
}

enum ProviderKind {
  patreon
}

enum OAuthPurpose {
  creator_ingest
  patron_entitlement
}

enum CredentialHealth {
  healthy
  degraded
  invalid
  revoked
}

/// Mirrors `UserAccount.auth_provider` in `src/identity/types.ts` (independent email/password vs Patreon-linked).
enum IdentityAuthProvider {
  independent
  patreon
}

model Tenant {
  id             String   @id @default(cuid())
  /// Relay `creator_id` (e.g. ingest / gallery scope) — unique tenant for DbIdentityStore.
  relayCreatorId String?  @unique @map("relay_creator_id")
  createdAt      DateTime @default(now()) @map("created_at")

  users    User[]
  creators CreatorProfile[]

  @@map("tenants")
}

model User {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  kind          UserKind
  emailHash     String?  @map("email_hash")
  /// Normalized email for `findByEmail` (lowercase); mirrors file `UserAccount.email` for lookup.
  emailNorm     String?  @map("email_norm")
  passwordHash  String?  @map("password_hash")
  identityAuthProvider IdentityAuthProvider @map("identity_auth_provider")
  patronPatreonUserId  String?  @map("patron_patreon_user_id")
  tierIds       String[] @default([]) @map("tier_ids")
  /// Backfill trace: stable id from `identity.json` / file store era (see integration-roadmap 2.3.x).
  legacyFileId  String?  @map("legacy_file_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions         Session[]
  providerAccounts ProviderAccount[]
  patronProfile    PatronProfile?
  creatorProfile   CreatorProfile?

  @@index([tenantId, kind])
  @@index([tenantId, emailNorm])
  @@map("users")
}

model Session {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 (or app-defined hash) of opaque token only — never store raw tokens (operations-and-security.md).
  tokenHash    String    @unique @map("token_hash")
  /// Backfill trace for file-backed sessions (integration-roadmap 2.3.x).
  legacyFileId String?   @map("legacy_file_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime? @map("expires_at")
  userAgent    String?   @map("user_agent")
  ipInet       String?   @map("ip_inet")
  revokedAt    DateTime? @map("revoked_at")

  @@index([userId, expiresAt])
  @@map("sessions")
}

model ProviderAccount {
  id             String         @id @default(cuid())
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       ProviderKind
  providerUserId String         @map("provider_user_id")
  displayName    String?        @map("display_name")
  createdAt      DateTime       @default(now()) @map("created_at")

  oauthCredential OAuthCredential?

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("provider_accounts")
}

model OAuthCredential {
  id                String            @id @default(cuid())
  providerAccountId String            @unique @map("provider_account_id")
  providerAccount   ProviderAccount   @relation(fields: [providerAccountId], references: [id], onDelete: Cascade)
  purpose           OAuthPurpose
  encryptedPayload  Bytes             @map("encrypted_payload")
  keyId             String            @map("key_id")
  healthStatus      CredentialHealth  @map("health_status")
  lastSuccessAt     DateTime?         @map("last_success_at")
  lastFailureAt     DateTime?         @map("last_failure_at")
  lastFailureCode   String?           @map("last_failure_code")
  expiresAtHint     DateTime?         @map("expires_at_hint")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@map("oauth_credentials")
}

model CreatorProfile {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  userId            String   @unique @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patreonCampaignId String?  @unique @map("patreon_campaign_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("creator_profiles")
}

model PatronProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  handle    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("patron_profiles")
}

// --- Canonical ingest + gallery (M3 Phase 3.1) — string `creator_id` matches Relay ingest scope (see `canonical-store.ts`) ---

enum PostUpstreamStatus {
  active
  deleted
}

enum MediaUpstreamStatus {
  active
  deleted
}

/// Patreon (or mapped) campaign row — `id` is stable `campaign_id` from `CampaignRow` / ingest.
model Campaign {
  id                String   @id
  creatorId         String   @map("creator_id")
  name              String
  upstreamUpdatedAt DateTime @map("upstream_updated_at")
  versionSeq        Int      @map("version_seq")

  posts Post[]
  tiers Tier[]

  @@index([creatorId])
  @@map("campaigns")
}

/// Access tier — `id` is a stable synthetic key (e.g. `${creator_id}::${relay_tier_id}`) because relay tier keys repeat across creators.
model Tier {
  id               String    @id @map("id")
  creatorId        String    @map("creator_id")
  /// File / API tier key (`TierRow.tier_id`), e.g. `patreon_tier_123`, `RELAY_TIER_PUBLIC`.
  relayTierId      String    @map("relay_tier_id")
  /// Opaque provider id for idempotency (Patreon tier id or same as `relay_tier_id` when unknown).
  providerTierId   String    @map("provider_tier_id")
  campaignId       String?   @map("campaign_id")
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  title            String
  amountCents      Int?      @map("amount_cents")
  upstreamUpdatedAt DateTime @map("upstream_updated_at")
  versionSeq       Int       @map("version_seq")

  postTiers PostTier[]

  @@unique([creatorId, providerTierId])
  @@index([creatorId])
  @@map("tiers")
}

/// Post — `id` is stable `post_id` from `PostRow` / ingest.
model Post {
  id               String             @id @map("id")
  campaignId       String             @map("campaign_id")
  campaign         Campaign           @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  creatorId        String             @map("creator_id")
  /// Patreon/API post id for idempotency when distinct from Relay `post_id`.
  providerPostId   String?            @map("provider_post_id")
  upstreamStatus   PostUpstreamStatus @map("upstream_status")
  /// Gallery / feed ordering — set from ingest (e.g. earliest `published_at` in versions).
  createdAt        DateTime           @map("created_at")

  versions  PostVersion[]
  postTiers PostTier[]
  mediaAssets MediaAsset[]

  @@unique([campaignId, providerPostId])
  @@index([campaignId, createdAt(sort: Desc)])
  @@map("posts")
}

model PostVersion {
  id               String   @id @default(cuid())
  postId           String     @map("post_id")
  post             Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  versionSeq       Int        @map("version_seq")
  upstreamRevision String     @map("upstream_revision")
  title            String
  description      String?
  publishedAt      DateTime   @map("published_at")
  tagIds           String[]   @default([]) @map("tag_ids")
  tierIds          String[]   @default([]) @map("tier_ids")
  mediaIds         String[]   @default([]) @map("media_ids")
  ingestedAt       DateTime   @map("ingested_at")

  @@unique([postId, versionSeq])
  @@index([postId])
  @@map("post_versions")
}

/// Media — `id` is stable `media_id` from `MediaRow`. `primary_post_id` indexes the canonical post link; `post_ids` mirrors file M:N.
model MediaAsset {
  id                      String             @id @map("id")
  creatorId               String             @map("creator_id")
  postIds                 String[]           @default([]) @map("post_ids")
  primaryPostId           String             @map("primary_post_id")
  post                    Post               @relation(fields: [primaryPostId], references: [id], onDelete: Cascade)
  upstreamStatus          MediaUpstreamStatus @map("upstream_status")
  currentVersionSeq       Int                @map("current_version_seq")
  currentUpstreamRevision String             @map("current_upstream_revision")
  currentMimeType         String?            @map("current_mime_type")
  currentUpstreamUrl      String?            @map("current_upstream_url")
  currentRole             String?            @map("current_role")
  currentIngestedAt       DateTime           @map("current_ingested_at")
  versionsJson            Json               @map("versions_json")

  @@index([primaryPostId])
  @@map("media_assets")
}

model PostTier {
  postId String @map("post_id")
  tierId String @map("tier_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([postId, tierId])
  @@map("post_tiers")
}

/// Replaces file-backed `SyncWatermarkStore` (`last_synced_at` per creator + campaign).
model SyncCursor {
  creatorId    String   @map("creator_id")
  campaignId   String   @map("campaign_id")
  lastSyncedAt DateTime @map("last_synced_at")
  updatedAt    DateTime @map("updated_at")

  @@id([creatorId, campaignId])
  @@map("sync_cursors")
}

/// Replaces file-backed `PatreonSyncHealthStore` (`last_post_scrape` / `last_member_sync` JSON blobs).
model CreatorSyncState {
  creatorId      String   @id @map("creator_id")
  lastPostScrape Json?    @map("last_post_scrape")
  lastMemberSync Json?    @map("last_member_sync")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("creator_sync_states")
}

/// Replaces `ingest_idempotency` map in `canonical.json` — `batch_key` is the SHA-256 hex from `ingestIdempotencyKey()`.
model IngestIdempotencyKey {
  id          String   @id @default(cuid())
  creatorId   String   @map("creator_id")
  batchKey    String   @map("batch_key")
  firstSeenAt DateTime @map("first_seen_at")

  @@unique([creatorId, batchKey])
  @@index([creatorId])
  @@map("ingest_idempotency_keys")
}

// --- Creator curation (M4 Phase 4.1) — Relay `creator_id` scope strings; no FK to `CreatorProfile` (see canonical pattern). ---

enum GalleryVisibility {
  visible
  hidden
  review
}

/// Replaces `gallery_post_overrides.json` — one row per (creator, post, media scope).
model PostOverride {
  id           String             @id @default(cuid())
  creatorId    String             @map("creator_id")
  postId       String             @map("post_id")
  /// Empty string = post-level override; otherwise canonical `media_id` for per-asset rows.
  mediaId      String             @default("") @map("media_id")
  addTagIds    String[]           @default([]) @map("add_tag_ids")
  removeTagIds String[]           @default([]) @map("remove_tag_ids")
  visibility   GalleryVisibility?
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([creatorId, postId, mediaId])
  @@index([creatorId])
  @@map("post_overrides")
}

/// Replaces artist `collections.json` Library rows — `id` is stable `collection_id` from file.
model LibraryCollection {
  id                  String   @id @map("id")
  creatorId           String   @map("creator_id")
  title               String
  description         String?
  coverMediaId        String?  @map("cover_media_id")
  accessCeilingTierId String?  @map("access_ceiling_tier_id")
  themeTagIds         String[] @default([]) @map("theme_tag_ids")
  sortOrder           Int      @map("sort_order")
  createdAt           DateTime @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  posts CollectionPost[]

  @@index([creatorId])
  @@map("library_collections")
}

model CollectionPost {
  collectionId String @map("collection_id")
  postId       String @map("post_id")
  sortIndex    Int    @map("sort_index")

  collection LibraryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([collectionId, postId])
  @@index([collectionId])
  @@map("collection_posts")
}

/// Replaces `gallery_saved_filters.json` — `id` is stable `filter_id` from file.
model SavedFilter {
  id        String   @id @map("id")
  creatorId String   @map("creator_id")
  name      String
  query     Json
  createdAt DateTime @map("created_at")

  @@index([creatorId])
  @@map("saved_filters")
}

/// Replaces `page_layout.json` — one row per Relay `creator_id`; full layout in JSON for round-trip.
model PageLayout {
  creatorId  String   @id @map("creator_id")
  layoutJson Json     @map("layout_json")
  version    Int      @default(1)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("page_layouts")
}
