{
  "name": "relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "dev:web": "npm run dev --prefix web",
    "dev:stack": "npm run build && concurrently -k -n api,web -c blue,magenta \"npm run start\" \"npm run dev:web\"",
    "test": "vitest run",
    "verify:m10": "npm run build && npm run test && node scripts/m10-token-log-scan.mjs && npm run lint --prefix web && npm run build --prefix web",
    "ledger-to-v0": "npm --prefix Automation run ledger-to-v0",
    "ledger-to-v0:dry": "npm --prefix Automation run ledger-to-v0:dry",
    "ledger-pull-v0-copy-block": "npm --prefix Automation run ledger-pull-v0-copy-block",
    "backfill:identity": "npm run build && node scripts/backfill-identity.mjs",
    "backfill:supabase-user-ids": "npm run build && node scripts/backfill-supabase-user-ids.mjs",
    "backfill:canonical": "npm run build && node scripts/backfill-canonical.mjs",
    "backfill:overrides": "npm run build && node scripts/backfill-gallery-overrides.mjs",
    "backfill:collections": "npm run build && node scripts/backfill-collections.mjs",
    "backfill:saved-filters": "npm run build && node scripts/backfill-saved-filters.mjs",
    "backfill:layout": "npm run build && node scripts/backfill-page-layout.mjs",
    "backfill:curation": "npm run build && node scripts/backfill-curation.mjs",
    "backfill:analytics": "npm run build && node scripts/backfill-analytics.mjs",
    "backfill:patron-engagement": "npm run build && node scripts/backfill-patron-engagement.mjs",
    "backfill:part2": "npm run build && node scripts/backfill-part2.mjs",
    "inspect:patreon-content": "node scripts/inspect-patreon-post-content.mjs",
    "probe:patreon-description": "node scripts/probe-patreon-post-description.mjs",
    "autopipeline": "node scripts/autopipeline-runner.mjs",
    "autosync:once": "npm run build && node dist/src/autosync-once.js",
    "autopipeline:run-until-barrier:dry": "node scripts/autopipeline-runner.mjs run-until-barrier --dry-run",
    "autopipeline:run-until-t011:dry": "node scripts/autopipeline-runner.mjs run-until-t011 --dry-run",
    "autopipeline:enforce-ready:dry": "node scripts/autopipeline-runner.mjs enforce-ready --dry-run",
    "claude:session-files": "node scripts/claude-session-files-download.mjs",
    "r2:smoke": "npm run build && node scripts/r2-upload-smoke.mjs",
    "validate:mt-env": "node scripts/validate-relay-mt-env.mjs --profile=relayapp",
    "validate:mt-env:local": "node scripts/validate-relay-mt-env.mjs --profile=local",
    "parity:check": "node scripts/pipeline-parity-check.mjs",
    "parity:secret": "node scripts/generate-pipeline-parity-secret.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@supabase/supabase-js": "^2.103.0",
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "patreon-dl": "^3.8.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/express": "^4.17.23",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "adm-zip": "^0.5.17",
    "concurrently": "^9.2.1",
    "prisma": "^7.7.0",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
