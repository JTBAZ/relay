{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["chrome"]
  },
  "include": ["src/**/*.ts", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
