{
  "manifest_version": 3,
  "name": "Relay — Patreon connector",
  "version": "0.1.0",
  "description": "Securely connect your Patreon account to Relay so Relay can back up your own posts and media.",
  "browser_specific_settings": {
    "gecko": {
      "id": "relay-extension@relayapp.me",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "Relay",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "scripts": ["src/background.ts"],
    "type": "module"
  },
  "permissions": ["cookies", "alarms", "storage"],
  "host_permissions": [
    "https://www.patreon.com/*",
    "https://relayapp.me/*"
  ],
  "externally_connectable": {
    "matches": ["https://relayapp.me/*"]
  }
}
