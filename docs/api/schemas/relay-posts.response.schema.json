{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.local/schemas/relay-posts.response.json",
  "title": "RelayCreatePostResponseData",
  "description": "Payload inside success envelope data for POST /api/v1/relay/posts (201). Post fields use camelCase as returned by Prisma in src/server.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["post", "version"],
  "properties": {
    "post": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "campaignId",
        "creatorId",
        "source",
        "isPublic",
        "requiredTierId"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "campaignId": { "type": "string" },
        "creatorId": { "type": "string" },
        "source": { "type": "string", "const": "RELAY" },
        "isPublic": { "type": "boolean" },
        "requiredTierId": {
          "type": ["string", "null"],
          "description": "When gated, canonical tiers.relay_tier_id (not Prisma Tier.id). Null when isPublic is true."
        }
      }
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version_seq",
        "upstream_revision",
        "title",
        "description",
        "published_at",
        "tag_ids",
        "tier_ids",
        "media_ids"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version_seq": { "type": "integer", "minimum": 1 },
        "upstream_revision": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "published_at": { "type": "string", "format": "date-time" },
        "tag_ids": { "type": "array", "items": { "type": "string" } },
        "tier_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "PostVersion.tierIds: canonical tiers.relay_tier_id values (gallery / entitlement / facet namespace). Not necessarily the same strings sent in the request tier_ids."
        },
        "media_ids": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
