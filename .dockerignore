# ── Git & IDE ──────────────────────────────────────────────
.git
.gitignore
.github
.vscode
.cursor
.claude

# ── Dependencies (rebuilt inside the image) ───────────────
node_modules
web/node_modules

# ── Build artifacts (rebuilt inside the image) ────────────
dist
web/.next
web/out
web/build
*.tsbuildinfo

# ── Runtime data (host-only, never ship) ──────────────────
.relay-data
.relay-backups
relay-data-archive
downloads

# ── Secrets & env (injected at runtime, never bake in) ────
.env
.env.*
web/.env.local
web/.env*.local
prisma/.env
prisma/.env.*

# ── Documentation & planning (not needed at runtime) ──────
.docs
docs
Automation
_relay_work_audit
_zip_extract_preview
design-archive
builder-boost-pack
ui-control-room-prototype
road map.md
AGENTS.md
README.md
LICENSE

# ── Tests (not needed in production image) ────────────────
tests
coverage
web/coverage

# ── Docker & CI (prevent recursive context) ───────────────
docker-compose.yml
Dockerfile

# ── OS / editor junk ─────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Prisma engine cache (regenerated by prisma generate) ─
prisma/migrations/**/migration_lock.toml
